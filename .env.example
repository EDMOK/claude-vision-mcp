# Vision MCP Server configuration

# Required: OpenAI-compatible vision API key
VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI-compatible API base URL
VISION_BASE_URL=https://api.openai.com/v1

# Optional: vision-capable model name
VISION_MODEL=gpt-4o

# Optional: hide this MCP tool when the main chat model has native vision
# VISION_TOOL_DISABLED=true
